# -- Ananya MCP Server Environment --
# Choose provider: groq | gemini | openai | ollama
LLM_PROVIDER=groq

# Keep LLM_MODEL explicit for reproducible behavior.
# You can change it any time without code edits.
LLM_MODEL=llama-3.3-70b-versatile

# Provider-specific keys (set only what you use)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ollama (used only when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434

API_BASE_URL=http://localhost/ananya/api.php
MCP_HOST=localhost
MCP_PORT=8000
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.2